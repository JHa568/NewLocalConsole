# Root compose env for docker-compose.prod.yml ${VAR} interpolation.
#
# In CI these are injected by .github/workflows/deploy.yml from GitHub Actions
# secrets + variables (environment "development") — you do NOT need this file on
# the server. Copy to .env only if running the prod stack by hand for testing.

# Django secret (prod refuses to boot on the dev default).
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# External shared Postgres.
SECRET_DB_USERNAME=patientia
SECRET_DB_PASSWORD=change-me
SECRET_DB_ADDRESS=your-db-host
SECRET_DB_PORT=5432
POSTGRES_DB=patientia

# Networking (include the server's public IP in ALLOWED_HOSTS).
ALLOWED_HOSTS=127.0.0.1,localhost,YOUR_SERVER_IP
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP
