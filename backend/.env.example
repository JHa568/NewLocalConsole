# Copy to backend/.env and fill in.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# WebAuthn (YubiKey). RP_ID is the domain (no scheme/port); ORIGIN must match
# the URL the browser loads the app from.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=NewLocalConsole
WEBAUTHN_ORIGIN=http://localhost:5173

# Google Calendar + Tasks (download OAuth client credentials from Google Cloud).
GOOGLE_CLIENT_SECRETS_PATH=client_secrets.json
GOOGLE_TOKEN_PATH=token.json
